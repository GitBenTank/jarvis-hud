{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Jarvis: Kill Local Stack",
      "type": "shell",
      "command": "pnpm local:stack:kill",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "Jarvis: Start HUD",
      "type": "shell",
      "command": "pnpm local:stack:start:jarvis",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "jarvisHud",
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "Jarvis: Start OpenClaw Gateway",
      "type": "shell",
