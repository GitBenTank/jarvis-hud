      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "openclawGateway",
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "Jarvis: Start Full Local Stack",
      "dependsOn": ["Jarvis: Start HUD", "Jarvis: Start OpenClaw Gateway"],
