# Jarvis HUD — environment variables
# Copy to .env.local and set values. Never commit secrets.
# See docs/setup/env.md for full reference.

# Storage
# JARVIS_ROOT=~/jarvis

# Code execution (code.apply)
# JARVIS_REPO_ROOT=/path/to/your/git/repo

# Optional: bound adapter filesystem targets (comma-separated absolute paths).
# Empty = no extra scope enforcement. See docs/execution-scope.md
# JARVIS_EXEC_ALLOWED_ROOTS=/path/to/jarvis/root,/path/to/git/repo
# JARVIS_EXEC_ALLOWED_REPOS=/path/to/git/repo

# Authentication
# JARVIS_AUTH_ENABLED=false
# JARVIS_AUTH_SECRET=                    # min 16 chars when auth enabled

# Connector ingress (OpenClaw)
# JARVIS_INGRESS_OPENCLAW_ENABLED=false
# JARVIS_INGRESS_OPENCLAW_SECRET=        # min 32 chars when ingress enabled
# JARVIS_INGRESS_ALLOWLIST_CONNECTORS=openclaw

# Demo / scripts (optional)
# PORT=3001
# JARVIS_HUD_BASE_URL=http://localhost:3001

# Optional: OpenClaw Control UI link in the HUD (navigation only; does not configure OpenClaw)
# OPENCLAW_CONTROL_UI_URL=http://127.0.0.1:18789
